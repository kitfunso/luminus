{
  "name": "luminus-mcp",
  "version": "0.1.0",
  "description": "Real-time European & UK electricity grid data via MCP. 56 tools, all free.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "luminus-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "verify": "npm test && npm run build && npm audit --omit=dev && npm pack --dry-run",
    "prepublishOnly": "npm run verify"
  },
  "keywords": [
    "mcp",
    "energy",
    "electricity",
    "entsoe",
    "grid",
    "europe",
    "power",
    "carbon-intensity",
    "renewables"
  ],
  "author": "Keith So",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitfunso/luminus.git"
  },
  "homepage": "https://github.com/kitfunso/luminus#readme",
  "bugs": {
    "url": "https://github.com/kitfunso/luminus/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.5.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "path-to-regexp": "8.4.0"
  }
}
